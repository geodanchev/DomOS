# DomOS Cashier MVP - Production Environment Configuration
# =========================================================
# SECURITY: Copy this to .env.production and configure ALL values!
# DO NOT commit .env.production to version control!

# App
APP_NAME="DomOS Cashier"
APP_VERSION="1.0.0"

# SECURITY: Must be false in production!
DEBUG=false

# Database - Use a secure PostgreSQL connection
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://domos_user:CHANGE_THIS_PASSWORD@localhost:5432/domos_cashier

# Security
# SECURITY: Generate a unique key for production!
# Command: python -c "import secrets; print(secrets.token_urlsafe(32))"
# The key MUST be at least 32 characters and unique to this deployment.
SECRET_KEY=GENERATE_A_SECURE_KEY_AT_LEAST_32_CHARACTERS

ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# Demo Data Initialization
# SECURITY: Must be false in production!
# Demo users should NOT be created in production.
INIT_DEMO_DATA=false

# Demo User Passwords - NOT USED when INIT_DEMO_DATA=false
# Leave empty or remove in production.
DEMO_ADMIN_PASSWORD=
DEMO_CASHIER_PASSWORD=

# CORS - Configure for your production domain
CORS_ORIGINS=["https://your-domain.com"]

# ==============================================================
# PRODUCTION CHECKLIST
# ==============================================================
# [ ] DEBUG=false
# [ ] SECRET_KEY is unique and at least 32 characters
# [ ] DATABASE_URL points to production PostgreSQL
# [ ] INIT_DEMO_DATA=false
# [ ] CORS_ORIGINS contains only your production domain(s)
# [ ] This file is NOT committed to version control
# [ ] Initial admin user created via secure database migration
# ==============================================================
