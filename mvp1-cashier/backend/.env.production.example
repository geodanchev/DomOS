# DomOS Cashier MVP - Production Environment Configuration
# Copy this file to .env.production and fill in your production values
# NEVER commit .env.production to version control!

# ============================================================================
# CRITICAL: REQUIRED VARIABLES
# ============================================================================
# These variables MUST be set for production deployment
# The application will fail to start if any of these are missing

# Environment identifier
# MUST be set to "production" for production deployments
ENVIRONMENT=production

# Database connection URL
# Format: postgresql://username:password@host:port/database_name
# Example: postgresql://domos_user:secure_password@db.example.com:5432/domos_production
# CRITICAL: Use a strong password and restrict database user permissions
DATABASE_URL=postgresql://domos_user:CHANGE_THIS_PASSWORD@localhost:5432/domos_cashier_prod

# Secret key for JWT token signing and session encryption
# Generate with: openssl rand -hex 32
# CRITICAL: Must be at least 32 characters long and cryptographically random
# NEVER use default/example values in production!
SECRET_KEY=CHANGE_THIS_TO_RANDOM_64_CHARACTER_HEX_STRING_GENERATED_WITH_OPENSSL

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# Application name (appears in logs, emails, etc.)
APP_NAME="DomOS Cashier"

# API version prefix
API_V1_STR=/api/v1

# Project name (used in documentation)
PROJECT_NAME="DomOS Cashier - Production"

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# JWT token expiration in minutes (default: 60 minutes = 1 hour)
# Consider shorter values for higher security (e.g., 30 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Password hashing algorithm
# Options: bcrypt (recommended), argon2, pbkdf2
PASSWORD_HASH_ALGORITHM=bcrypt

# CORS allowed origins (comma-separated list)
# Example: https://domos.example.com,https://app.domos.example.com
# NEVER use "*" in production!
CORS_ORIGINS=https://your-production-domain.com

# ============================================================================
# LOGGING AND MONITORING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use INFO or WARNING in production (DEBUG only for troubleshooting)
LOG_LEVEL=INFO

# Enable detailed logging (true/false)
# Set to false in production for better performance
DEBUG=false

# ============================================================================
# DATABASE INITIALIZATION
# ============================================================================

# WARNING: INIT_DB should NEVER be set to true in production!
# This flag triggers initialization of demo/seed data
# For production, user initialization happens automatically on first run
# Leave commented out or explicitly set to false
# INIT_DB=false

# ============================================================================
# OPTIONAL: EMAIL CONFIGURATION (for future notifications)
# ============================================================================

# SMTP server for sending emails (uncomment when needed)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@domos.example.com
# SMTP_PASSWORD=your_smtp_password
# SMTP_FROM=noreply@domos.example.com
# SMTP_FROM_NAME="DomOS Cashier"

# ============================================================================
# OPTIONAL: BACKUP CONFIGURATION
# ============================================================================

# Automatic database backup schedule (cron format)
# Example: 0 2 * * * = Daily at 2:00 AM
# BACKUP_SCHEDULE="0 2 * * *"

# Backup retention period in days
# BACKUP_RETENTION_DAYS=30

# Backup storage path
# BACKUP_PATH=/var/backups/domos

# ============================================================================
# OPTIONAL: PERFORMANCE TUNING
# ============================================================================

# Database connection pool size
# Adjust based on your server resources and expected load
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# Request timeout in seconds
# REQUEST_TIMEOUT=30

# ============================================================================
# OPTIONAL: FEATURE FLAGS
# ============================================================================

# Enable/disable specific features (true/false)
# FEATURE_THERMAL_PRINTER=true
# FEATURE_EMAIL_NOTIFICATIONS=false
# FEATURE_AUTO_OBLIGATIONS=true

# ============================================================================
# DEPLOYMENT INFORMATION
# ============================================================================
# These are optional metadata fields for tracking deployments

# Deployment environment name (useful for multiple production instances)
# DEPLOYMENT_ENV=production-main

# Git commit hash (automatically set by CI/CD)
# GIT_COMMIT_SHA=

# Deployment timestamp (automatically set by CI/CD)
# DEPLOYMENT_TIMESTAMP=

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
#
# Before deploying to production:
#
# [ ] Copy this file to .env.production
# [ ] Generate strong SECRET_KEY with: openssl rand -hex 32
# [ ] Set strong DATABASE_URL password
# [ ] Configure CORS_ORIGINS with your actual domain(s)
# [ ] Set ENVIRONMENT=production
# [ ] Set LOG_LEVEL=INFO or WARNING
# [ ] Set DEBUG=false
# [ ] Verify INIT_DB is NOT set to true (or commented out)
# [ ] Configure database backups
# [ ] Set up monitoring and alerting
# [ ] Test database connection before deployment
# [ ] Review all security settings
# [ ] Document deployment date and version
#
# After first deployment:
#
# [ ] Login with default admin credentials
# [ ] IMMEDIATELY change all default passwords
# [ ] Create additional admin users
# [ ] Configure building-specific settings
# [ ] Test critical workflows (payments, obligations, reports)
# [ ] Verify backup procedures
# [ ] Set up monitoring dashboards
#
# ============================================================================
