# DomOS Cashier Backend - Cloud Run Production Dockerfile
# Multi-stage build for minimal production image

# =============================================================================
# Stage 1: Builder - Install dependencies
# =============================================================================
FROM python:3.11-slim as builder

# Set build-time environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /build

# Install build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# Create virtual environment
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"

# Copy requirements and install Python dependencies into venv
COPY requirements.txt .
RUN pip install --upgrade pip && pip install -r requirements.txt

# =============================================================================
# Stage 2: Production - Minimal runtime image
# =============================================================================
FROM python:3.11-slim as production

# Labels for container registry
LABEL org.opencontainers.image.title="DomOS Cashier Backend" \
      org.opencontainers.image.description="Digital cashier for residential building management" \
      org.opencontainers.image.vendor="DomOS" \
      org.opencontainers.image.source="https://github.com/geodanchev/DomOS"

# Set runtime environment variables
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    # Virtual environment path
    PATH="/opt/venv/bin:$PATH" \
    PYTHONPATH=/app \
    # Cloud Run sets PORT, default to 8080
    PORT=8080 \
    # Production defaults
    ENVIRONMENT=production \
    DEBUG=false \
    INIT_DEMO_DATA=false

WORKDIR /app

# Install runtime dependencies only
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq5 \
    curl \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Create non-root user for security
RUN groupadd --gid 1000 appgroup \
    && useradd --uid 1000 --gid appgroup --shell /bin/bash --create-home appuser

# Copy virtual environment from builder stage (includes uvicorn executable)
COPY --from=builder /opt/venv /opt/venv

# Copy application code
COPY --chown=appuser:appgroup . .

# Remove unnecessary files
RUN rm -rf tests/ *.md .env* alembic/ \
    Dockerfile* .dockerignore .gitignore \
    *.sh *.backup *.db venv/ .pytest_cache/

# Switch to non-root user
USER appuser

# Health check for container orchestration
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:8080/health/live || exit 1

# Expose the port Cloud Run expects
EXPOSE 8080

# Run with uvicorn using python -m to ensure correct path resolution
# Cloud Run sends SIGTERM, uvicorn handles graceful shutdown
CMD ["sh", "-c", "python -m uvicorn app.main:app --host 0.0.0.0 --port $PORT --workers 1 --timeout-keep-alive 65 --access-log --log-level info"]
