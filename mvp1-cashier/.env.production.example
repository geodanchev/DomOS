# ===========================================
# DomOS Cashier MVP - Production Environment
# ===========================================
# Copy this file to .env.production and fill in your values
# Usage: docker compose -f docker-compose.prod.yml --env-file .env.production up -d

# ===========================================
# REQUIRED - Domain and SSL
# ===========================================
# Your domain name (without https://)
DOMAIN=yourdomain.com

# Email for Let's Encrypt certificate notifications
ACME_EMAIL=admin@yourdomain.com

# ===========================================
# REQUIRED - Security
# ===========================================
# JWT secret key for authentication tokens
# Generate with: openssl rand -hex 32
SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars

# PostgreSQL database password
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=change-this-to-a-secure-password

# Traefik dashboard authentication (optional but recommended)
# Generate with: htpasswd -nb admin yourpassword
# Note: escape $ signs by doubling them ($ -> $$)
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$ruca84Hq$$mbjdMZBAG.KWn7vfN/SNK/

# ===========================================
# Database Configuration (optional)
# ===========================================
# PostgreSQL username (default: postgres)
POSTGRES_USER=postgres

# PostgreSQL database name (default: domos_cashier)
POSTGRES_DB=domos_cashier

# ===========================================
# Application Settings (optional)
# ===========================================
# JWT token expiration in minutes (default: 1440 = 24 hours)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ===========================================
# Rate Limiting Configuration (optional)
# ===========================================
# These values protect your API from abuse and brute-force attacks.
# Adjust based on your traffic patterns and security requirements.

# --- General API Rate Limit ---
# Applied to all /api/* endpoints except /api/auth/*
# Requests allowed per period (default: 100)
RATE_LIMIT_API_AVG=100

# Burst allowance above average (default: 50)
# Allows temporary spikes up to average + burst
RATE_LIMIT_API_BURST=50

# Time period for rate calculation (default: 1m)
# Supported: s (seconds), m (minutes), h (hours)
RATE_LIMIT_API_PERIOD=1m

# --- Authentication Rate Limit ---
# Applied to /api/auth/* endpoints (login, register, etc.)
# Much stricter to prevent brute-force attacks
# Requests allowed per period (default: 5)
RATE_LIMIT_AUTH_AVG=5

# Burst allowance for auth endpoints (default: 10)
RATE_LIMIT_AUTH_BURST=10

# Time period for auth rate calculation (default: 1m)
RATE_LIMIT_AUTH_PERIOD=1m

# --- IP Detection ---
# Depth in X-Forwarded-For header to find real client IP
# Set to 1 if behind single proxy (default)
# Set to 2 if behind two proxies (e.g., Cloudflare + Load Balancer)
RATE_LIMIT_IP_DEPTH=1

# ===========================================
# Logging Configuration (optional)
# ===========================================
# Traefik log level: DEBUG, INFO, WARN, ERROR (default: INFO)
TRAEFIK_LOG_LEVEL=INFO

# ===========================================
# Example Configurations
# ===========================================

# --- High Traffic Site ---
# RATE_LIMIT_API_AVG=500
# RATE_LIMIT_API_BURST=200

# --- Extra Security (stricter auth limits) ---
# RATE_LIMIT_AUTH_AVG=3
# RATE_LIMIT_AUTH_BURST=5

# --- Behind Cloudflare + Load Balancer ---
# RATE_LIMIT_IP_DEPTH=2

# --- Development/Testing (more lenient) ---
# RATE_LIMIT_API_AVG=1000
# RATE_LIMIT_API_BURST=500
# RATE_LIMIT_AUTH_AVG=20
# RATE_LIMIT_AUTH_BURST=30
