# ===========================================
# DomOS Cashier MVP - Git Ignore
# ===========================================

# ----- SECURITY: Sensitive Files -----
# NEVER commit these files!
.env.production
.env.local
*.pem
*.key
secrets.env
*.secret

# ----- Environment Files -----
# .env is okay for development defaults only
# .env.production must NEVER be committed
backend/.env.production
frontend/.env.production

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
.venv/
ENV/

# ----- Node.js -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ----- Build outputs -----
frontend/dist/
*.build/

# ----- Database -----
*.db
*.sqlite
*.sqlite3
*.backup
*.sql.gz
*.sql
db_dump*.sql

# ----- Docker Environment Files -----
.env.docker

# ----- IDE/Editor -----
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-*

# ----- OS Files -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ----- Testing -----
.coverage
htmlcov/
.tox/
.nox/
.pytest_cache/
.cache/
coverage.xml
*.cover

# ----- Logs -----
*.log
logs/

# ----- Docker -----
# Don't ignore docker-compose files, they're needed
# But ignore any local overrides
docker-compose.override.yml

# ----- Misc -----
*.bak
*.tmp
*.temp
.~lock.*
=*
