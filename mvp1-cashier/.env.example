# ===========================================
# DomOS Cashier MVP - Environment Configuration
# ===========================================
# This is a template file showing all available environment variables.
# Copy this to .env for development or .env.production for production.
#
# SECURITY WARNING:
# - NEVER commit .env or .env.production files to version control!
# - Use strong, unique values for all secrets in production
# - Rotate credentials regularly

# ===========================================
# Backend Configuration
# ===========================================
# See backend/.env.production.example for detailed backend settings

# Database Connection
DATABASE_URL=postgresql://postgres:change_this_password@db:5432/domos_cashier

# Security
SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ALGORITHM=HS256

# Application
APP_NAME="DomOS Cashier"
APP_VERSION="1.0.0"
DEBUG=false

# Demo Data (for development only)
INIT_DEMO_DATA=false
DEMO_ADMIN_PASSWORD=
DEMO_CASHIER_PASSWORD=

# CORS Origins
CORS_ORIGINS=["http://localhost:5173","http://localhost"]

# ===========================================
# Production Deployment (docker-compose.prod.yml)
# ===========================================
# See .env.production.example for full production configuration

# Domain and SSL
DOMAIN=yourdomain.com
ACME_EMAIL=admin@yourdomain.com

# PostgreSQL Production
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-to-a-secure-password
POSTGRES_DB=domos_cashier

# Traefik Dashboard (optional)
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$ruca84Hq$$mbjdMZBAG.KWn7vfN/SNK/

# Rate Limiting
RATE_LIMIT_API_AVG=100
RATE_LIMIT_API_BURST=50
RATE_LIMIT_API_PERIOD=1m
RATE_LIMIT_AUTH_AVG=5
RATE_LIMIT_AUTH_BURST=10
RATE_LIMIT_AUTH_PERIOD=1m
RATE_LIMIT_IP_DEPTH=1

# Logging
TRAEFIK_LOG_LEVEL=INFO

# ===========================================
# Development Notes
# ===========================================
# 1. For local development:
#    - Copy this file to .env
#    - Use docker-compose.dev.yml or docker-compose.yml
#    - Set DEBUG=true and INIT_DEMO_DATA=true if needed
#
# 2. For production deployment:
#    - Copy .env.production.example to .env.production
#    - Configure ALL production values
#    - Use docker-compose.prod.yml
#    - Ensure DEBUG=false and INIT_DEMO_DATA=false
#
# 3. Backend-specific settings:
#    - See backend/.env.production.example for more options
#    - Backend settings override root settings when present
