# Cloud Build ignore file
# This overrides .gitignore patterns that incorrectly exclude needed files

# Include .gitignore patterns by default
#!include:.gitignore

# Standard ignores
.git/
.gitignore
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
ENV/
.venv/
*.egg-info/
.eggs/
.pytest_cache/
.coverage
htmlcov/
.tox/
.vscode/
.idea/
*.swp
*.swo
.env
.env.*
!.env.example
!.env.production.example
*.db
*.sqlite3
*.backup
.DS_Store
Thumbs.db
*.log

# Node.js
node_modules/
.npm/
coverage/
.nyc_output/

# Build artifacts (but NOT src/lib/)
dist/
build/

# Do NOT ignore src/lib/ - it contains required source files
# The .gitignore 'lib/' pattern incorrectly excludes frontend/src/lib/

# Python virtual environment lib folders (these should be ignored)
# But we're explicit about paths to avoid excluding src/lib/
mvp1-cashier/backend/venv/
mvp1-cashier/backend/lib/
mvp1-cashier/backend/lib64/
backend/venv/
backend/lib/
backend/lib64/
